#!/bin/sh

run() {

opts=`getopt -l device:,time:,out:,start:,help,verbose d:t:o:s:hv "$@"`

if [[ $? != 0 || $# == 0 ]]; then
    err "invalid arguments\m$usage"
fi

eval set -- "$opts"

out=/dev/stdout
while test $# -ne 0; do
    case $1 in
    -h|--help)
        echo $usage
        exit;;
    -d|--device)
        devnum=$2
        shift 2;;
    -t|--time)
        rectime=($rectime $2)
        shift 2;;
    -o|--out)
        out=$2
        shift 2;;
    -s|--start)
        start=$1
        shift 2;;
    -v|--verbose)
        verbose=1
        shift;;
    --)
        shift
        break;;
    esac
done

if test $# >= 2; then
    shift
    err extra parameters: "$@"
elif test $# == 0; then
    err missing channel
fi

channel=$1

if test -z "$devnum"; then
    verbose detect and lock device...
    if test $channel -lt 100; then
        devnums="9 11"
    else
        devnums="8 10"
    fi
    for i in $devnums; do
        fuse_b25 /dev/dvb/adapter$i
        if test $? = 0; then
            devnum=$i
            break
        fi
    done
    if test -z "$devnum"; then
        err all device are busy or not found
    fi
else
    verbose lock device...
    fuse_b25 /dev/dvb/adapter$devnum
    mounted=$?
    if test "$mounted" != 0; then
        err device is busy or not found
    fi
fi

if test -n "$verbose"; then
    verbose devnum: $devnum
    verbose rectime: $rectime
    verbose out: $out
    verbose channel: $channel
fi

verbose tune...
tune "$devnum" "$channel" &
tunepid=$!
sleep 0.1
if ! pgrep -P $$ tune; then
    msg tune failed
else
    msg $tunepid
    verbose recording...
    if test -n "$rectime"; then
        timeout --foreground $rectime cat /dev/dvb/adapter$devnum/dvr0 >$out
        exitcode=$?
        # if test $exitcode != 124; then
        #     exit $exitcode
        # fi
    else
        cat /dev/dvb/adapter$devnum/dvr0 >$out
    fi
fi
kill $tunepid

sleep 2
fusermount -u /dev/dvb/adapter$devnum

exit $exitcode

}

msg() {
    echo `basename $0`: "$@" >&2
}
err() {
    msg "$@"
    exit 1
}
verbose() {
    if test -n $verbose; then
        echo "$@" >&2
    fi
}

usage=\
'usage: tune2 [option...] channel
options:
  -d --device NUMBER  specify device number (default: auto detect)
  -t --time TIME      recording time (default: no limit)
  -o --out FILE       output file (default: stdout)
  -v --verbose        show verbose message
  -h --help           show this help'

run "$@"

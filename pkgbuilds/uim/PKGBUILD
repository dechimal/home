options=(
    ${_debug:+'!strip'}
)

_src="$pkgname-$pkgver"

prepare() {
  files='japanese-act.scm japanese-azik.scm japanese-custom.scm japanese-kana.scm japanese-kzik.scm japanese.scm skk.scm skk-custom.scm skk-editor.scm'
  if ! test -L uim; then
      ln -s "$_src" uim
  fi
  rm -rf "$_src"/sigscheme
  cp -r "$srcdir/sigscheme-$_sigscheme_ver" "$_src"/sigscheme
  for orig in $files; do
    orig="$srcdir/$_src/scm/$orig"
    iconved=${orig%.scm}-utf8.scm
    iconv -f EUC-JISX0213 -t UTF-8 <"$orig" | sed 's/ja-/ja-utf8-/g' >"$iconved"
    case $orig in
      */skk*.scm)
        mv "$iconved" "$orig"
        ;;
    esac
  done
  for file in "$srcdir"/[0-9]*.patch; do
    msg "patch $file"
    patch -d "$srcdir/$_src" -p1 <"$file"
  done
  cd "$srcdir/$_src"
  autoreconf -f
}

build() {
  mkdir -p "$srcdir"/build
  cd "$srcdir"/build

  "$srcdir/$_src"/configure \
    --prefix=/usr \
    --libexecdir=/usr/lib/uim \
    --with-qt5-immodule \
    --with-qt5 \
    --without-anthy \
    --with-skk \
    --disable-kde-applet \
    --disable-kde4-applet \
    --disable-kde5-applet \
    --disable-gnome-applet \
    --disable-gnome3-applet \
    ${_debug:+--enable-debug --enable-backtrace}

  make -j$(nproc) configure
  find -\( -name '*Makefile*' -o -name '*.mk' -\) -exec sed -Ei 's/\s((-W.[^,]'${_debug:+'|-O'}')\S*|-W\b)/ /g' {} +
  make -j$(nproc)
}

# check() {
#   cd "$_archive"
#
#   make check
# }

package() {
  cd "$srcdir"/build

  make DESTDIR="$pkgdir" install
  install -Dm644 -t "$pkgdir"/usr/share/licenses/"$pkgname" "$srcdir/$_src"/COPYING
  install -Dm755 -t "$pkgdir"/usr/bin "$srcdir"/update-utf8-skk-jisyo
  install -Dm644 -t "$pkgdir"/usr/share/libalpm/hooks "$srcdir"/update-utf8-skk-jisyo.hook
}
